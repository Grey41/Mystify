{
    "manifest_version": 3,
    "name": "Mystify",
    "version": "0.4.0",
    "permissions": ["scripting", "storage"],
    "description": "Quality of life overlay for Mystera Legacy",
    "content_scripts": [
        {
            "matches": ["https://www.mysteralegacy.com/play/full.php", "https://www.mysteralegacy.com/play-ml/"],
            "js": ["content.js"],
            "run_at": "document_start"
        }
    ],
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png"
    },
    "web_accessible_resources": [{
        "resources": ["inject.js"],
        "matches": ["https://www.mysteralegacy.com/*"]
    }]
}